+
+        if clean_msg1 == clean_msg2:
+            return True
+
+        # Guard against very short normalised strings (e.g. a message that was
+        # entirely an address becomes "XXX") producing spurious substring matches
+        # that would incorrectly deduplicate unrelated errors.
+        _MIN_SUBSTRING_LEN = 10
+        if (len(clean_msg1) >= _MIN_SUBSTRING_LEN and clean_msg1 in clean_msg2):
+            return True
+        if (len(clean_msg2) >= _MIN_SUBSTRING_LEN and clean_msg2 in clean_msg1):
+            return True
+
+        return False
     
