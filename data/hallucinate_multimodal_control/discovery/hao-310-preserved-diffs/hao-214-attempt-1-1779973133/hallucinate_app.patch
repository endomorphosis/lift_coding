+    def test_substring_match_after_normalisation(self):
+        """A shorter normalised message that is a substring of the longer should match (HAO-214)."""
+        # After normalising the volatile hex address, msg1 becomes a prefix of msg2.
+        msg1 = "Crash at 0xdeadbeef in module graphics"
+        msg2 = "Crash at 0xDEADBEEF in module graphics during render pass"
+        self.assertTrue(self._similar(msg1, msg2))
+
+    def test_short_normalised_message_not_falsely_matched(self):
+        """Substring guard: a normalised string shorter than 10 chars must not
+        produce a false positive when it happens to be a prefix of the other
+        normalised string (HAO-214)."""
+        # msg1 normalises to "bad: XXX" (8 chars < _MIN_SUBSTRING_LEN=10).
+        # msg2 normalises to "bad: XXX for extra context here" (31 chars).
+        # "bad: XXX" IS a substring of the longer form — the guard must block
+        # that path so unrelated messages are not reported as duplicates.
+        msg1 = "bad: 0x1"
+        msg2 = "bad: 0x2 for extra context here"
+        # Exact-match check: "bad: XXX" != "bad: XXX for extra context here"
+        # Substring check skipped because len("bad: XXX") = 8 < 10
+        self.assertFalse(self._similar(msg1, msg2))
+
