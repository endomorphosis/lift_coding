+        """Helper method to get current chain height.
+
+        Mock stats file errors propagate to callers so corrupt local state is
+        reported instead of being hidden behind a synthetic fallback height.
+        """
+        if self.mock_mode or self.gateway_mode:
+            # Try to get from mock storage first
+            mock_base = os.path.expanduser("~/.ipfs_kit/mock_filecoin")
+            network_file = os.path.join(mock_base, "network", "stats.json")
+
+            if os.path.exists(network_file):
+                with open(network_file, "r", encoding="utf-8") as f:
+                    stats = json.load(f)
+
+                if not isinstance(stats, dict):
+                    raise ValueError(
+                        f"Invalid mock Filecoin stats in {network_file}: expected JSON object"
+                    )
+                if "chain_height" not in stats:
+                    raise ValueError(f"Missing chain_height in {network_file}")
+
+                chain_height = stats["chain_height"]
+                try:
+                    return int(chain_height)
+                except (TypeError, ValueError) as exc:
+                    raise ValueError(
+                        f"Invalid chain_height in {network_file}: {chain_height!r}"
+                    ) from exc
+
+        # Try to get real chain height. The request helper logs transport/API
+        # failures and returns None, so only malformed successful responses
+        # need to be surfaced here.
+        chain_head = self._make_api_request("Filecoin.ChainHead")
+        if isinstance(chain_head, dict) and "Height" in chain_head:
+            chain_height = chain_head["Height"]
+            try:
+                return int(chain_height)
+            except (TypeError, ValueError) as exc:
+                raise ValueError(
+                    f"Invalid Height in Filecoin.ChainHead response: {chain_height!r}"
+                ) from exc
+
+        return None
 
